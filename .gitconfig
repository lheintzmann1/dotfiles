[user]
	name = lheintzmann1
	email = lheintzmann1@disroot.org
[init]
	defaultBranch = main
[push]
	default = simple
[pull]
	rebase = true
[rerere]
	enabled = true
[core]
	editor = micro
	preloadindex = true
	fscache = true
[gc]
	auto = 256
[delta]
	navigate = true
	light = false
	side-by-side = true
[safe]
	directory = *
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
